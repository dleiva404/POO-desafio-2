<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <File name="ArchivoLog" fileName="logs/mediateca.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%p] %c{1} - %m%n"/>
        </File>

        <Console name="Consola" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} [%p] %c{1} - %m%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="ArchivoLog"/>
            <AppenderRef ref="Consola"/>
        </Root>
    </Loggers>
</Configuration>